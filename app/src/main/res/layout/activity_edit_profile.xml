<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/gradient_kotak"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="@color/white"
                    android:padding="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit Profile"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginStart="12dp"/>

            </LinearLayout>

            <!-- foto profile -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:background="@color/white">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder_png"
                    app:shapeAppearanceOverlay="@style/circleImage"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>

                <TextView
                    android:id="@+id/btnUbahFoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ubah Foto Profil"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:padding="8dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:background="@color/white">

                <!-- edit nama -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"/>

                <com.example.storyhub.utils.GradientEditText
                    android:id="@+id/etNama"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/chip_background"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:inputType="textPersonName"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/txtNamaCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/40"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                </LinearLayout>

                <!-- edit username -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="16dp"/>

                <com.example.storyhub.utils.GradientEditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/chip_background"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:inputType="text"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/txtUsernameCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/20"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                </LinearLayout>

                <!-- edit bio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bio"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="16dp"/>

                <com.example.storyhub.utils.GradientEditText
                    android:id="@+id/etBio"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/chip_background"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="12dp"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/txtBioCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/80"
                        android:textSize="11sp"
                        android:textColor="#888888"/>

                </LinearLayout>

            </LinearLayout>

            <!-- tombol update profil -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPerbarui"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Perbarui Profil"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/button_gradient"
                android:backgroundTint="@null"
                android:layout_margin="16dp"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</RelativeLayout>