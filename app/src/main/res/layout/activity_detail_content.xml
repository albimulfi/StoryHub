<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- banner art -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="320dp">

                <ImageView
                    android:id="@+id/imgBanner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#70000000"/>

                <!-- tombol back -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="@color/white"
                    android:padding="8dp"
                    android:layout_margin="16dp"/>

                <!-- bookmark -->
                <ImageView
                    android:id="@+id/btnBookmark"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:tint="@color/white"
                    android:padding="8dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:src="@drawable/ic_bookmark"/>

                <!-- bagian art info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgCover"
                        android:layout_width="100dp"
                        android:layout_height="150dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/placeholder"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_gravity="bottom">

                        <TextView
                            android:id="@+id/txtTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textStyle="bold"
                            android:textSize="22sp"
                            android:textColor="@color/white"/>

                        <TextView
                            android:id="@+id/txtCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCCCCC"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/txtTagline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CCCCCC"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <TextView
                                android:id="@+id/txtRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:textSize="13sp"/>

                            <TextView
                                android:id="@+id/txtReviewers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:layout_marginStart="12dp"/>

                            <TextView
                                android:id="@+id/txtChapters"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:layout_marginStart="12dp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- button continue reading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnContinueReading"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Reading Now"
                    android:textColor="@color/primary"
                    android:background="@drawable/chip_background"
                    android:backgroundTint="@null"/>

            </LinearLayout>

            <!-- tabs -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:id="@+id/tabContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnTabOverview"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Overview"
                        android:paddingHorizontal="20dp"
                        android:textColor="@color/primary"
                        android:background="@null"
                        android:textStyle="bold"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnTabChapters"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Chapters"
                        android:paddingHorizontal="20dp"
                        android:textColor="@color/black"
                        android:background="@null"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnTabReviews"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Reviews"
                        android:paddingHorizontal="20dp"
                        android:textColor="@color/black"
                        android:background="@null"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnTabComments"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Komentar"
                        android:paddingHorizontal="20dp"
                        android:textColor="@color/black"
                        android:background="@null"/>

                </LinearLayout>

            </HorizontalScrollView>


            <LinearLayout
                android:id="@+id/layoutOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- sinopsis -->
                <com.example.storyhub.utils.GradientText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Synopsis"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/txtSynopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#555555"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="8dp"/>

                <!-- info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="16dp"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Author"
                            android:textColor="#888888"/>

                        <com.example.storyhub.utils.GradientText
                            android:id="@+id/txtAuthor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Artist"
                            android:textColor="#888888"/>

                        <com.example.storyhub.utils.GradientText
                            android:id="@+id/txtArtist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            android:textColor="#888888"/>

                        <com.example.storyhub.utils.GradientText
                            android:id="@+id/txtStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Published"
                            android:textColor="#888888"/>

                        <com.example.storyhub.utils.GradientText
                            android:id="@+id/txtPublished"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- genre art -->
                <com.example.storyhub.utils.GradientText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Genres"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="16dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="8dp">
                    <LinearLayout
                        android:id="@+id/containerGenres"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </HorizontalScrollView>

                <!-- tag art -->
                <com.example.storyhub.utils.GradientText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tags"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="8dp">
                    <LinearLayout
                        android:id="@+id/containerTags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </HorizontalScrollView>

                <!-- mood art -->
                <com.example.storyhub.utils.GradientText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moods"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="8dp">
                    <LinearLayout
                        android:id="@+id/containerMoods"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>
                </HorizontalScrollView>

                <!-- screenshots game (buat game doang) -->
                <LinearLayout
                    android:id="@+id/layoutScreenshots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="18dp"
                    android:visibility="gone">

                    <com.example.storyhub.utils.GradientText
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Screenshots"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginTop="8dp">

                        <LinearLayout
                            android:id="@+id/containerScreenshots"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"/>

                    </HorizontalScrollView>

                </LinearLayout>

            </LinearLayout>

            <!-- tab chapter -->
            <LinearLayout
                android:id="@+id/layoutChapters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerChapters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- tab reviews suatu art  -->
            <LinearLayout
                android:id="@+id/layoutReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAddReview"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="+ Tulis Review"
                    android:textColor="@color/primary"
                    android:background="@drawable/chip_background"
                    android:backgroundTint="@null"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="18dp"/>

                <TextView
                    android:id="@+id/txtTotalReviews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="8dp"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/txtEmptyReview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum ada review"
                    android:textColor="@color/gray_dark"
                    android:layout_margin="16dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerReviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- tab komentar suatu art -->
            <LinearLayout
                android:id="@+id/layoutComments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:visibility="gone">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAddComment"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="+ Tulis Komentar"
                    android:textColor="@color/primary"
                    android:background="@drawable/chip_background"
                    android:backgroundTint="@null"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="18dp"/>

                <TextView
                    android:id="@+id/txtTotalComments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="8dp"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/txtEmptyComment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum ada komentar"
                    android:textColor="@color/gray_dark"
                    android:layout_margin="16dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerComments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="60dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</RelativeLayout>